# Copy to the repo root .env (or this folder) and fill in. Never commit real keys.

# Cursor Agent SDK key (Dashboard -> API Keys). Powers the models. REQUIRED for live.
CURSOR_API_KEY=

# Live data defaults to ESPN's public API (DATA_SOURCE=espn) which needs NO key and has the
# real 2026 World Cup. The key below is only needed if you switch DATA_SOURCE=api_football
# (whose free tier covers seasons 2022-2024 only).
API_FOOTBALL_KEY=

# Optional overrides
# DATA_SOURCE=espn          # espn (default) | api_football | (USE_MOCK_DATA for offline)
# DEFAULT_MODEL=composer-2.5
# PROB_TEMPERATURE=0.7      # <1 = sharper/more decisive picks, 1.0 = raw model output
# USE_MOCK_DATA=1           # serve bundled offline data instead of the live API
# ESPN_WINDOW=20260601-20260731
# WC_SEASON=2022            # only used when DATA_SOURCE=api_football
